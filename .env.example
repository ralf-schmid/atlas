# Alpaca Paper Trading API Keys — native Broker-Accounts je Persona (ADR-0001)
# Nur Paper-/Dummy-Werte. Niemals echte Keys hier eintragen oder committen.
# Live-Keys existieren vor Phase 6 in keiner Umgebung (Sicherheits-Invariante 5).

ALPACA_PAPER_VULTURE_KEY_ID=PKDUMMYVULTUREKEYID000000
ALPACA_PAPER_VULTURE_SECRET_KEY=dummySecretKeyReplaceMeVultureXXXXXXXXXXXXX

ALPACA_PAPER_GUARDIAN_KEY_ID=PKDUMMYGUARDIANKEYID00000
ALPACA_PAPER_GUARDIAN_SECRET_KEY=dummySecretKeyReplaceMeGuardianXXXXXXXXXXXX

ALPACA_PAPER_CHARTIST_KEY_ID=PKDUMMYCHARTISTKEYID00000
ALPACA_PAPER_CHARTIST_SECRET_KEY=dummySecretKeyReplaceMeChartistXXXXXXXXXXXX

# Marktdaten fuer InternalLedgerAdapter (HYPE/CONTRA/CRYPTOR, F002) — jeder gueltige
# Alpaca-Paper-Key funktioniert hier (reine Leseabfrage), siehe F002 §2.
ALPACA_MARKET_DATA_KEY_ID=PKDUMMYMARKETDATAKEYID000
ALPACA_MARKET_DATA_SECRET_KEY=dummySecretKeyReplaceMeMarketDataXXXXXXXXXXX

# Postgres (docker-compose.yml), F003 DB-Schema — Paper-/Dummy-Wert, passt zu docker-compose.yml
DATABASE_URL=postgresql+psycopg://atlas:atlas@localhost:5432/atlas
# Optional: eigenes Postgres-Passwort (Default in docker-compose.yml ist "atlas";
# bei Aenderung auch ALTER ROLE im bestehenden Cluster + DATABASE_URL anpassen)
#POSTGRES_PASSWORD=atlas
# Optional: erlaubte CORS-Origins der API, kommasepariert
# (Default: http://localhost:3000,http://localhost:3001)
#CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
# Optional: Interface-Bindung fuer Postgres (5432) + LiteLLM (4000).
# Default 0.0.0.0 (lokales Dev); auf der UGREEN auf die LAN-IP setzen, damit die
# Ports nur im 192.168.178.0/24 erreichbar sind (docs/deployment.md):
#ATLAS_BIND_IP=192.168.178.116

# Telegram-Bot (F005) — Dummy-Werte bis Ralf echten Token + Chat-ID liefert
# (CLAUDE.md Entscheidungsstand Punkt 6). Nur die konfigurierte Chat-ID wird akzeptiert.
TELEGRAM_BOT_TOKEN=000000:dummy-bot-token-replace-me
TELEGRAM_CHAT_ID=000000000

# LiteLLM-Proxy (F006, docker-compose.yml) — Dummy-Werte, bis Ralf echte Provider-Keys liefert.
ANTHROPIC_API_KEY=sk-ant-dummy-replace-me
GROQ_API_KEY=gsk-dummy-replace-me
LITELLM_MASTER_KEY=sk-litellm-dummy-master-key-replace-me

# Grafana auf der UGREEN (bestehende Instanz, ARCHITECTURE.md "Grafana: bestehende
# Instanz") — Postgres-Datasource + Container-Health-Alert werden darueber per API
# eingerichtet. Service-Account-Token, kein Provider-Key (Anleitung: docs/deployment.md).
GRAFANA_URL=http://nas.fritz.box:3000
GRAFANA_API_KEY=dummy-replace-me

# EDGAR-RSS-Ingestion (F009, config/ingestion.yaml). SEC verlangt einen aussage-
# kraeftigen User-Agent (Name + Kontakt) fuer automatisierte Zugriffe, siehe
# https://www.sec.gov/os/webmaster-faq#developers — kein Secret, aber echte Kontakt-
# daten noetig, bevor gegen den echten Feed gepollt wird (Dummy-Wert = kein Live-Poll).
EDGAR_USER_AGENT=ATLAS/1.0 (dummy-replace-me@example.com)

# aktienfinder-Grabbing (F012, config/ingestion.yaml) — Ablageort fuer die Beleg-
# Screenshots (Lineage, ARCHITECTURE.md §3.5.2). Kein Secret, aber ein echter,
# beschreibbarer Pfad auf der UGREEN statt dieses Dummy-Werts.
AKTIENFINDER_SCREENSHOT_DIR=/data/ingest/aktienfinder/screenshots
# Login fuer die echte Playwright-Session gegen aktienfinder.net (F012).
AKTIENFINDER_USERNAME=dummy-replace-me
AKTIENFINDER_PASSWORD=dummy-replace-me

# Publications Mail-Trigger (F013, config/ingestion.yaml "publications"-Sektion).
# PUBLICATIONS_INGEST_DIR muss mit F011s Ablage-Konvention uebereinstimmen
# (<dir>/<slug>/<YYYY-MM-DD>.pdf). N8N_PUBLICATIONS_WEBHOOK_SECRET schuetzt den
# FastAPI-Webhook (src/api/routes_ingestion.py), den n8n aufruft — im n8n-Workflow
# selbst als "HTTP Header Auth"-Credential hinterlegt (n8n/publications-mail-trigger.json),
# nicht als Klartext im Workflow.
PUBLICATIONS_INGEST_DIR=/data/ingest/publications
N8N_PUBLICATIONS_WEBHOOK_SECRET=dummy-replace-me

# Reddit-Ingestion (F039, config/ingestion.yaml "reddit"-Sektion) — CRYPTORs
# Krypto-Subreddit-Quelle. OAuth2 App-only (client_credentials), kein persoenliches
# Reddit-Login noetig. App einmalig unter reddit.com/prefs/apps registrieren
# ("script"-Typ), Client-ID/-Secret von dort. Reddit verlangt einen
# aussagekraeftigen User-Agent (sonst Rate-Limiting/Sperre), siehe
# https://github.com/reddit-archive/reddit/wiki/API#rules.
REDDIT_CLIENT_ID=dummy-replace-me
REDDIT_CLIENT_SECRET=dummy-replace-me
REDDIT_USER_AGENT=atlas-research/1.0 (dummy-replace-me)

# Nicht hier eintragen: die IMAP-Zugangsdaten fuer den n8n-Mail-Trigger auf die
# Boersenmedien-Benachrichtigungsmail. n8n ist eine bestehende, separate Instanz
# (ARCHITECTURE.md "n8n: bestehende Instanz"), nicht Teil dieses docker-compose-
# Stacks — die Zugangsdaten gehoeren in n8n's eigenen Credential-Store, nicht in
# dieses .env.
